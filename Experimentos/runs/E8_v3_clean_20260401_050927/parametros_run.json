{
  "dataset_path": "/home/emilio/Documentos/RAdAR/Datos_Modelo_ML/datos_ML_master_indice_aceptación_digital.xlsx",
  "feature_columns": [
    "sentimiento_medios",
    "v5_agua_neto",
    "v5_alumbrado_neto",
    "v5_americo_neto",
    "v5_basura_neto",
    "v5_corrupcion_neto",
    "v5_delitos_neto",
    "v5_morena_neto",
    "v5_obras_neto",
    "v5_prevencion_neto",
    "v5_vialidad_neto"

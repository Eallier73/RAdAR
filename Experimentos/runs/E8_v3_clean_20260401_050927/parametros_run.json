  "initial_train_size": 40,
  "lags": [
    1,
    2,
    3,
    4,
    5,
    6
  ],
  "model": "hybrid_residual_catboost_regressor_prophet_exogenous_regressor",
  "model_params": {
    "base_feature_mode": "all",
    "base_model": "catboost_regressor",
    "base_params": {
